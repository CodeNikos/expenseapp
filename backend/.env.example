DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/expenseapp
JWT_SECRET_KEY=cambiar-por-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_OPEN_REGISTRATION=true

# Cifrado de Mistral API Key y Odoo API Key en PostgreSQL (Fernet).
# Generar una clave: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotacion: anade la nueva clave al INICIO (se cifra con la primera; al descifrar se prueba cada clave en orden).
# Si se omite, los nuevos valores se guardan en claro (solo recomendable en desarrollo local).
# SECRETS_ENCRYPTION_KEYS=

# Correos (minusculas) que reciben rol admin al arrancar la API (separados por coma).
# INITIAL_ADMIN_EMAILS=

# URL publica del frontend (enlace en correos de recuperacion de contrasena).
PUBLIC_FRONTEND_URL=http://localhost:5173
# Validez del enlace de recuperacion (minutos).
# PASSWORD_RESET_TTL_MINUTES=60

# SMTP opcional. Si SMTP_HOST esta vacio, el enlace solo se registra en log del servidor (desarrollo).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
